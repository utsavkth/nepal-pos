# Copy this file to .env and fill in the value before running docker compose.
# .env is gitignored — never commit real secrets.

# Flask session signing key — keep stable so admin logins survive restarts.
# Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# NOTE: there is no admin password here. The admin password is set on the
# first visit to /admin (a "Set Admin Password" screen) and stored hashed in
# the database. Change it later from inside the admin panel.
