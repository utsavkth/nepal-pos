# Copy this file to .env and fill in real values before running docker compose.
# .env is gitignored — never commit real secrets.

# Password for the /admin panel (staff-facing). Choose something strong.
ADMIN_PASSWORD=change-me-to-a-strong-password

# Flask session signing key — keep stable so admin logins survive restarts.
# Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string
