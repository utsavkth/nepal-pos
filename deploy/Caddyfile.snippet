# ============================================================================
# Nepal Grocery POS — append this block to the Pi's Caddyfile
# (the file bind-mounted into the Caddy container at /etc/caddy/Caddyfile).
#
# HTTPS uses a real Let's Encrypt cert from `tailscale cert` (required so the
# iPhones can use the camera — CLAUDE.md decisions 4 & 7). Caddy runs as a
# host-networked container, so:
#   - it reaches the POS container via the host's published port 5050, and
#   - it reads the cert from /etc/caddy/certs, already bind-mounted into Caddy.
#
# If you rename the Pi's Tailscale device to `pos`, change the domain below to
# pos.tailea48bb.ts.net and re-issue the cert (the .crt/.key filenames can stay).
# ============================================================================

uk-homeserver.tailea48bb.ts.net {
    tls /etc/caddy/certs/uk-homeserver.crt /etc/caddy/certs/uk-homeserver.key
    reverse_proxy localhost:5050
}
